{
  "name": "@mui-search/adapter-wordpress",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./sync": {
      "types": "./src/sync.ts",
      "default": "./src/sync.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "sync": "node --env-file=.env src/index.ts sync",
    "sync:full": "node --env-file=.env src/index.ts sync:full",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tidbcloud/serverless": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2"
  }
}
