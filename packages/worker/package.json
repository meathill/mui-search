{
  "name": "@mui-search/worker",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --config wrangler.jsonc",
    "build": "pnpm --filter @mui-search/playground build",
    "deploy": "pnpm run build && wrangler deploy --config wrangler.jsonc",
    "typecheck": "tsc --noEmit",
    "types:worker": "wrangler types --config wrangler.jsonc",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "node --env-file-if-exists=.dev.vars ./node_modules/drizzle-kit/bin.cjs migrate --config drizzle.config.ts",
    "db:d1:create": "wrangler d1 migrations create DB --config wrangler.jsonc",
    "db:d1:migrate:local": "wrangler d1 migrations apply DB --local --config wrangler.jsonc",
    "db:d1:migrate:remote": "wrangler d1 migrations apply DB --remote --config wrangler.jsonc"
  },
  "dependencies": {
    "@mui-search/adapter-wordpress": "workspace:*",
    "@mui-search/shared": "workspace:*",
    "@tidbcloud/serverless": "^0.2.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.10",
    "mysql2": "^3.20.0",
    "wrangler": "^4.80.0"
  }
}
