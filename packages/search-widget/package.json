{
  "name": "mui-search",
  "version": "0.1.1",
  "description": "轻量级站内搜索组件，支持自动补全、热门内容和多语言；可通过 ESM import 或 CDN script 引入。",
  "keywords": ["search", "widget", "site-search", "preact", "autocomplete", "wordpress"],
  "license": "MIT",
  "author": "Meathill",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meathill/mui-search.git",
    "directory": "packages/search-widget"
  },
  "homepage": "https://github.com/meathill/mui-search#readme",
  "bugs": {
    "url": "https://github.com/meathill/mui-search/issues"
  },
  "type": "module",
  "main": "./dist/mui-search.cjs",
  "module": "./dist/mui-search.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/mui-search.mjs",
      "require": "./dist/mui-search.cjs"
    },
    "./style.css": "./dist/search-widget.css",
    "./locale/*": {
      "types": "./dist/locale/*.d.ts",
      "import": "./dist/locale/*.mjs",
      "require": "./dist/locale/*.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": ["**/*.css"],
  "scripts": {
    "build": "pnpm run build:iife && pnpm run build:lib && pnpm run build:locales && pnpm run build:css && pnpm run build:types",
    "build:iife": "vite build --config vite.config.ts",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:locales": "node scripts/build-locale-files.mjs",
    "build:css": "node scripts/build-css.mjs",
    "build:types": "tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@mui-search/shared": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.5.2",
    "clsx": "^2.1.1",
    "lodash-es": "^4.18.1",
    "preact": "^10.29.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vite": "^7.3.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
